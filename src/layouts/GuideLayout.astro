---
import '../styles/global.css'

interface Props {
  title: string
  description?: string
  section: string
  sectionHref: string
  prevArticle?: { title: string; href: string }
  nextArticle?: { title: string; href: string }
}

const {
  title,
  description = '',
  section,
  sectionHref,
  prevArticle,
  nextArticle,
} = Astro.props

const siteUrl = 'https://ecmonster.jp'
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString()
---

<!doctype html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0" />
  <title>{title} - EC モンスター</title>
  <meta name="description" content={description || title} />
  <link rel="canonical" href={canonicalUrl} />
  <meta property="og:title" content={`${title} - EC モンスター`} />
  <meta property="og:description" content={description || title} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:type" content="article" />
  <meta property="og:site_name" content="EC モンスター" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700;900&family=Inter:wght@400;500;700&display=swap" rel="stylesheet" />

  <script async src="https://www.googletagmanager.com/gtag/js?id=G-53F0YCGQDS"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-53F0YCGQDS');
  </script>
</head>
<body class="bg-white">
  <!-- Header -->
  <header class="bg-navy text-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-16">
        <a href="/" class="text-xl font-bold text-primary">EC MONSTER</a>
        <nav class="hidden md:flex items-center space-x-8">
          <a href="/" class="text-sm hover:text-primary transition-colors">トップ</a>
          <a href="/ai/" class="text-sm hover:text-primary transition-colors">AIコンサル</a>
          <a href="/movie/" class="text-sm hover:text-primary transition-colors">楽天市場動画</a>
          <a href="/contact/" class="text-sm hover:text-primary transition-colors">お問い合わせ</a>
        </nav>
      </div>
    </div>
  </header>

  <!-- Breadcrumb -->
  <nav class="bg-slate-light border-b">
    <div class="max-w-4xl mx-auto px-4 py-3 text-sm text-slate">
      <a href="/" class="hover:text-primary">トップ</a>
      <span class="mx-2">/</span>
      <a href="/movie/" class="hover:text-primary">楽天市場動画</a>
      <span class="mx-2">/</span>
      <a href={sectionHref} class="hover:text-primary">{section}</a>
      <span class="mx-2">/</span>
      <span class="text-dark">{title}</span>
    </div>
  </nav>

  <!-- Article Content -->
  <main class="max-w-4xl mx-auto px-4 py-12">
    <h1 class="text-3xl font-bold mb-8 text-dark">{title}</h1>
    <article class="prose prose-lg max-w-none">
      <slot />
    </article>

    <!-- Prev/Next Navigation -->
    <div class="mt-12 pt-8 border-t grid grid-cols-1 md:grid-cols-2 gap-4">
      {prevArticle && (
        <a href={prevArticle.href} class="block p-4 rounded-lg border hover:border-primary hover:bg-red-50 transition-colors">
          <span class="text-sm text-slate">前の記事</span>
          <p class="font-medium text-dark mt-1">{prevArticle.title}</p>
        </a>
      )}
      {nextArticle && (
        <a href={nextArticle.href} class="block p-4 rounded-lg border hover:border-primary hover:bg-red-50 transition-colors md:text-right md:ml-auto">
          <span class="text-sm text-slate">次の記事</span>
          <p class="font-medium text-dark mt-1">{nextArticle.title}</p>
        </a>
      )}
    </div>

    <!-- CTA -->
    <div class="mt-12 text-center bg-navy rounded-2xl p-8 text-white">
      <h2 class="text-2xl font-bold mb-4">楽天市場で成功する方法を動画で学ぶ</h2>
      <p class="text-slate mb-6">2話無料公開中</p>
      <a href="https://lms.ecmonster.jp/p/rakuten2" class="inline-block bg-primary hover:bg-primary-dark text-white font-bold px-8 py-4 rounded-full transition-colors">
        無料で視聴する
      </a>
    </div>
  </main>

  <!-- Footer -->
  <footer class="bg-navy text-white py-8">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <div class="flex flex-wrap justify-center gap-4 text-sm text-slate mb-4">
        <a href="/" class="hover:text-primary transition-colors">トップ</a>
        <a href="/ai/" class="hover:text-primary transition-colors">AIコンサル</a>
        <a href="/movie/" class="hover:text-primary transition-colors">楽天市場動画</a>
        <a href="/contact/" class="hover:text-primary transition-colors">お問い合わせ</a>
        <a href="/legal-notice/" class="hover:text-primary transition-colors">特定商取引法</a>
      </div>
      <p class="text-sm text-slate">&copy; EC モンスター All Rights Reserved.</p>
    </div>
  </footer>
</body>
</html>
