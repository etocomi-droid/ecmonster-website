---
interface Props {
  title: string
  description?: string
  bodyClass?: string
}

const {
  title,
  description = 'モールや自社ECに出店運営されている方向けのECに特化したAIコンサルのご紹介と、モール出店運営者に向けた攻略法を分かりやすく解説した動画のご案内です。',
  bodyClass = '',
} = Astro.props

const siteUrl = 'https://ecmonster.jp'
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString()
---

<!DOCTYPE html>
<html dir="ltr" lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <script is:inline>
    var ua = navigator.userAgent.toLowerCase();
    var isiOS = (ua.indexOf('iphone') > -1) || (ua.indexOf('ipad') > -1);
    if (isiOS) {
      var viewport = document.querySelector('meta[name="viewport"]');
      if (viewport) {
        var viewportContent = viewport.getAttribute('content');
        viewport.setAttribute('content', viewportContent + ', user-scalable=no');
      }
    }
  </script>

  <!-- WordPress Theme CSS -->
  <link rel="stylesheet" href="/wp-assets/css/reset.css" type="text/css" />
  <link rel="stylesheet" href="/wp-assets/css/style.css" type="text/css" />
  <slot name="css" />

  <meta name="format-detection" content="telephone=no" />
  <title>{title}</title>

  <!-- SEO -->
  <meta name="description" content={description} />
  <meta name="robots" content="max-image-preview:large" />
  <link rel="canonical" href={canonicalUrl} />

  <!-- Favicon -->
  <link rel="icon" href="/favicon.ico" sizes="any">
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">

  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-53F0YCGQDS"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-53F0YCGQDS');
  </script>

  <!-- Google Ads -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=AW-1003850219"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'AW-1003850219');
  </script>

  <!-- OGP -->
  <meta property="og:locale" content="ja_JP" />
  <meta property="og:site_name" content={`EC モンスター - ${description}`} />
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:image" content={`${siteUrl}/wp-assets/img/common/logo.png`} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalUrl} />
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />

  <slot name="head" />
</head>
<body class={bodyClass}>
  <header class="header">
    <div class="header-inner">
      <div class="logo"><a href="/"><img src="/wp-assets/img/common/logo.png" alt="EC MONSTER" /></a></div>
      <div class="h-navi">
        <nav>
          <ul class="gnavi">
            <li><a href="/">トップ</a></li>
            <li><a href="/ai/">ECモンスターAIコンサル</a></li>
            <li><a href="/movie/">ECモンスター楽天市場動画</a></li>
            <li><a href="/web/">WEBシステム開発</a></li>
            <li><a href="/ec/">越境ECサイト</a></li>
            <li><a href="/faq/">よくある質問</a></li>
            <li><a href="/contact/">お問い合わせ</a></li>
            <li><a href="/login/">ログイン</a></li>
          </ul>
        </nav>
      </div>
      <div class="gnavi-btn"><span></span></div>
    </div>
  </header>

  <slot />

  <footer class="footer">
    <div class="l_inner">
      <ul class="f-navi">
        <li><a href="/">トップ</a></li>
        <li><a href="/ai/">ECモンスターAIコンサル</a></li>
        <li><a href="/movie/">ECモンスター楽天市場動画</a></li>
        <li><a href="/web/">WEBシステム開発</a></li>
        <li><a href="/ec/">越境ECサイト</a></li>
        <li><a href="/faq/">よくある質問</a></li>
        <li><a href="/contact/">お問い合わせ</a></li>
        <li><a href="/legal-notice/">特定商取引法</a></li>
        <li><a href="/terms/">利用規約</a></li>
        <li><a href="/privacy-policy/">プライバシーポリシー</a></li>
      </ul>
      <p class="copyright">(C) EC モンスター</p>
    </div>
  </footer>
  <div class="overlay"></div>

  <!-- Mobile navigation script -->
  <script is:inline>
    (function() {
      var btn = document.querySelector('.gnavi-btn');
      if (btn) {
        btn.addEventListener('click', function() {
          document.body.classList.toggle('naviOpen');
        });
      }
      var overlay = document.querySelector('.overlay');
      if (overlay) {
        overlay.addEventListener('click', function() {
          document.body.classList.remove('naviOpen');
        });
      }
    })();
  </script>
</body>
</html>
