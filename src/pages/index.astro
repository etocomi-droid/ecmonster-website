<style>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
:root{
  --white:#FFF;--off:#FAFAFA;--gray:#F5F5F5;--border:#E8E8E8;
  --dark:#1A1A1A;--body:#3D3D3D;--light:#595959;--muted:#767676;
  --red:#C8272E;--red-pale:rgba(200,39,46,.05);
  --r:4px;
}
html{scroll-behavior:smooth}
body{font-family:'Noto Sans JP','Inter',sans-serif;background:var(--white);color:var(--body);line-height:1.9;letter-spacing:.03em;font-size:15px}
img{display:block;max-width:100%}
a{color:inherit;text-decoration:none}
a:focus-visible,button:focus-visible{outline:2px solid var(--red);outline-offset:2px}
strong{font-weight:700;color:var(--dark)}

/* SKIP LINK */
.skip{position:absolute;top:-100px;left:16px;background:var(--dark);color:var(--white);padding:8px 16px;border-radius:var(--r);font-size:13px;z-index:200;transition:.2s}
.skip:focus{top:16px}

/* HEADER */
.hdr{position:fixed;top:0;left:0;right:0;z-index:100;padding:0 60px;height:120px;display:flex;align-items:center;justify-content:space-between;background:rgba(255,255,255,.97);-webkit-backdrop-filter:blur(12px);backdrop-filter:blur(12px);border-bottom:1px solid transparent;transition:.3s}
.hdr.scrolled{border-color:var(--border)}
.hdr-logo{max-width:280px}
.nav{display:flex;align-items:center;gap:32px}
.nav a{font-size:13px;color:var(--light);font-weight:500;transition:.2s}
.nav a:hover{color:var(--dark)}
.nav .nav-cta{background:var(--dark);color:var(--white);padding:10px 24px;border-radius:var(--r);font-weight:600;transition:all .3s}
.nav .nav-cta:hover{background:var(--red)}
.m-toggle{display:none;background:none;border:none;cursor:pointer;width:32px;height:32px;position:relative}
.m-toggle span{display:block;width:22px;height:1.5px;background:var(--dark);position:absolute;left:5px;transition:.3s}
.m-toggle span:nth-child(1){top:9px}.m-toggle span:nth-child(2){top:15px}.m-toggle span:nth-child(3){top:21px}

/* COMMON */
.sec{padding:120px 60px}
.sec-in{max-width:1080px;margin:0 auto}
.sec-ey{font-size:12px;font-weight:600;color:var(--red);text-transform:uppercase;letter-spacing:.15em;margin-bottom:16px}
.spacer{height:40px}
.btn-d{display:inline-flex;align-items:center;gap:8px;background:var(--dark);color:var(--white);padding:15px 32px;border-radius:var(--r);font-size:14px;font-weight:600;transition:.3s;border:none;cursor:pointer}
.btn-d:hover{background:var(--red)}
.btn-g{display:inline-flex;align-items:center;gap:8px;background:transparent;color:var(--dark);padding:15px 32px;border-radius:var(--r);font-size:14px;font-weight:600;transition:.3s;border:1px solid var(--muted)}
.btn-g:hover{border-color:var(--dark)}

/* BLOCK 1: HERO */
.hero{min-height:100vh;display:grid;grid-template-columns:1fr 1fr;align-items:center;padding:120px 60px 0;gap:60px;background:var(--white)}
.hero-copy{max-width:520px;margin-left:auto;padding:40px 0}
.hero h1{font-size:clamp(32px,4.5vw,48px);font-weight:900;color:var(--dark);line-height:1.3;letter-spacing:-.02em;margin-bottom:32px}
.hero-body{font-size:16px;color:var(--body);line-height:2.2;margin-bottom:40px}
.hero-acts{display:flex;gap:12px;flex-wrap:wrap}
.hero-img{border-radius:var(--r);overflow:hidden}
.hero-img img{width:100%;aspect-ratio:4/3;object-fit:cover}

/* BLOCK 2: EMPATHY */
.empathy{background:var(--off)}
.empathy-layout{display:grid;grid-template-columns:.55fr .45fr;gap:60px;align-items:center}
.empathy-grid{display:flex;flex-direction:column;gap:12px;margin-bottom:32px}
.empathy-item{padding:18px 22px;border:1px solid var(--border);border-radius:var(--r);background:var(--white);font-size:14px;color:var(--body);line-height:1.8;display:flex;align-items:flex-start;gap:12px}
.empathy-item::before{content:'';width:5px;height:5px;border-radius:50%;background:var(--red);margin-top:10px;flex-shrink:0}
.empathy-close{font-size:16px;color:var(--dark);line-height:2.1}
.empathy-close em{font-style:normal;color:var(--red);font-weight:700}
.empathy-photo{border-radius:var(--r);overflow:hidden}
.empathy-photo img{width:100%;aspect-ratio:4/3;object-fit:cover}

/* BLOCK 3: BRAND DEFINITION */
.brand{text-align:center}
.brand h2{font-size:clamp(26px,3.5vw,36px);font-weight:800;color:var(--dark);line-height:1.5;margin-bottom:16px}
.brand-body{font-size:16px;color:var(--body);line-height:2.2;max-width:640px;margin:0 auto 48px}
.brand-line{display:flex;align-items:center;justify-content:center;gap:0;max-width:700px;margin:0 auto 48px;height:80px}
.brand-dots{display:flex;flex-direction:column;gap:6px;margin-right:-4px}
.brand-dot{width:7px;height:7px;border-radius:50%;background:var(--body);opacity:.4}
.brand-merge{width:200px;height:2px;background:linear-gradient(90deg,var(--body) 0%,var(--red) 40%,var(--red) 100%);position:relative}
.brand-merge::after{content:'';position:absolute;right:-6px;top:-5px;width:12px;height:12px;border-radius:50%;background:var(--red)}
.brand-pillars{display:grid;grid-template-columns:repeat(4,1fr);max-width:720px;margin:0 auto;border:1px solid var(--border)}
.brand-pillar{padding:24px 0;text-align:center;font-size:13px;font-weight:700;color:var(--dark);letter-spacing:.05em;border-right:1px solid var(--border);transition:.2s}
.brand-pillar:last-child{border-right:none}
.brand-pillar:hover{background:var(--red-pale);color:var(--red)}

/* BLOCK 4: 7 FUNCTIONS */
.functions{background:var(--off)}
.func-top{display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:center;margin-bottom:48px}
.func-top h2{font-size:clamp(24px,3vw,32px);font-weight:800;color:var(--dark);line-height:1.5;margin-bottom:16px}
.func-top-desc{font-size:15px;color:var(--light);line-height:2;max-width:560px}
.func-top-photo{border-radius:var(--r);overflow:hidden}
.func-top-photo img{width:100%;aspect-ratio:16/10;object-fit:cover}
.func-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px}
.func-card{background:var(--white);border:1px solid var(--border);border-radius:var(--r);padding:28px 24px;display:block;color:inherit;transition:.3s}
.func-card:hover{border-color:var(--red);box-shadow:0 2px 16px rgba(0,0,0,.04)}
.func-icon{width:36px;height:36px;border:1.5px solid var(--dark);border-radius:var(--r);display:flex;align-items:center;justify-content:center;margin-bottom:16px}
.func-icon svg{width:16px;height:16px;stroke:var(--dark);fill:none;stroke-width:1.5;stroke-linecap:round;stroke-linejoin:round}
.func-name{font-size:15px;font-weight:700;color:var(--dark);margin-bottom:6px}
.func-desc{font-size:13px;color:var(--light);line-height:1.8}
.func-svc{font-size:11px;color:var(--muted);margin-top:10px;padding-top:10px;border-top:1px solid var(--border)}
.func-links{display:flex;flex-direction:column;gap:6px;margin-top:12px}
.func-link{display:block;font-size:13px;font-weight:600;color:var(--white);background:var(--dark);padding:8px 14px;border-radius:var(--r);text-align:center;text-decoration:none;transition:.3s}
.func-link:hover{background:var(--red)}

/* BLOCK 5: DIFFERENTIATION */
.diff h2{font-size:clamp(24px,3vw,32px);font-weight:800;color:var(--dark);line-height:1.5;margin-bottom:16px}
.diff-body{font-size:15px;color:var(--light);line-height:2.1;margin-bottom:40px}
.diff-cols{display:grid;grid-template-columns:1fr 1fr;gap:20px}
.diff-col{padding:28px 24px;border:1px solid var(--border);border-radius:var(--r)}
.diff-col.ec{border-color:rgba(200,39,46,.2);background:var(--red-pale)}
.diff-col-label{font-size:11px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.1em;margin-bottom:12px}
.diff-col.ec .diff-col-label{color:var(--red)}
.diff-col p{font-size:14px;line-height:2;color:var(--body)}
.diff-col.ec p{color:var(--dark);font-weight:500}

/* BLOCK 6: TRUST */
.trust{background:var(--off)}
.trust-layout{display:grid;grid-template-columns:1.2fr .8fr;gap:64px;align-items:center}
.trust h2{font-size:clamp(24px,3vw,32px);font-weight:800;color:var(--dark);line-height:1.5;margin-bottom:16px}
.trust-body{font-size:15px;color:var(--body);line-height:2.1;margin-bottom:32px}
.trust-photo{border-radius:var(--r);overflow:hidden}
.trust-photo img{width:100%;height:auto}
.trust-nums{display:grid;grid-template-columns:repeat(3,1fr);gap:12px}
.trust-num{padding:20px;border:1px solid var(--border);border-radius:var(--r);background:var(--white);text-align:center}
.trust-num-val{font-size:28px;font-weight:800;color:var(--dark);line-height:1}
.trust-num-val span{color:var(--red)}
.trust-num-label{font-size:11px;color:var(--muted);margin-top:6px}

/* BLOCK 7: CHANGE */
.change h2{font-size:clamp(24px,3vw,32px);font-weight:800;color:var(--dark);line-height:1.5;margin-bottom:16px}
.change-sub{font-size:15px;color:var(--light);line-height:2;max-width:560px}
.change-list{display:grid;grid-template-columns:repeat(2,1fr);gap:12px;margin:40px 0}
.change-item{display:flex;align-items:center;gap:14px;padding:18px 24px;border:1px solid var(--border);border-radius:var(--r)}
.change-dot{width:18px;height:18px;border:1.5px solid var(--red);border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.change-dot::after{content:'';width:6px;height:6px;border-radius:50%;background:var(--red)}
.change-item span{font-size:14px;color:var(--dark);font-weight:500}
.change-close{font-size:16px;color:var(--dark);line-height:2}
.change-close em{font-style:normal;color:var(--red);font-weight:700}

/* BLOCK 8: GUIDE */
.guide{background:var(--off)}
.guide h2{font-size:clamp(24px,3vw,32px);font-weight:800;color:var(--dark);line-height:1.5;margin-bottom:16px}
.guide-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-bottom:32px}
.guide-card{background:var(--white);border:1px solid var(--border);border-radius:var(--r);padding:28px 24px;transition:.3s;display:block}
.guide-card:hover{border-color:var(--red);box-shadow:0 2px 16px rgba(0,0,0,.04)}
.guide-q{font-size:14px;font-weight:700;color:var(--dark);margin-bottom:10px;line-height:1.6}
.guide-a{font-size:12px;color:var(--red);font-weight:600}
.guide-a::after{content:' \2192';font-size:14px}
.guide-fallback{text-align:center;padding:28px;border:1px solid var(--border);border-radius:var(--r);background:var(--white)}
.guide-fallback p{font-size:14px;color:var(--light);margin-bottom:16px}

/* BLOCK 9: FINAL CTA */
.final-cta{background:var(--white);padding:0}
.final-cta-inner{display:grid;grid-template-columns:1fr 1fr;min-height:480px}
.final-cta-text{display:flex;flex-direction:column;justify-content:center;padding:80px 60px}
.final-cta h2{font-size:clamp(24px,3vw,30px);font-weight:800;color:var(--dark);line-height:1.5;margin-bottom:16px}
.final-cta-desc{font-size:15px;color:var(--light);line-height:2;max-width:560px;margin-bottom:36px}
.final-acts{display:flex;gap:12px;flex-wrap:wrap}
.final-cta-photo{overflow:hidden}
.final-cta-photo img{width:100%;height:100%;object-fit:cover}

/* FOOTER */
.ftr{background:#111;color:rgba(255,255,255,.65);padding:64px 60px 32px}
.ftr-in{max-width:1080px;margin:0 auto}
.ftr-top{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:40px;padding-bottom:40px;border-bottom:1px solid rgba(255,255,255,.1)}
.ftr-brand{max-width:320px}
.ftr-brand p{font-size:13px;line-height:1.9;margin-top:16px;color:rgba(255,255,255,.55)}
.ftr-logo{max-width:280px;background:#fff;padding:16px 20px;border-radius:var(--r)}
.ftr-links{display:flex;gap:56px}
.ftr-col h4{font-size:11px;font-weight:700;color:rgba(255,255,255,.6);text-transform:uppercase;letter-spacing:1.5px;margin-bottom:14px}
.ftr-col a{display:block;font-size:13px;color:rgba(255,255,255,.55);padding:3px 0;transition:.2s}
.ftr-col a:hover{color:rgba(255,255,255,.9)}
.ftr-btm{display:flex;justify-content:space-between;align-items:center}
.ftr-btm p{font-size:11px;color:rgba(255,255,255,.35)}
.ftr-legal{display:flex;gap:20px}
.ftr-legal a{font-size:11px;color:rgba(255,255,255,.35);transition:.2s}
.ftr-legal a:hover{color:rgba(255,255,255,.65)}

/* RESPONSIVE */
@media(max-width:1024px){
  .hero,.empathy-layout,.trust-layout,.final-cta-inner,.func-top{grid-template-columns:1fr}
  .hero-copy{margin:0;max-width:100%}
  .func-grid{grid-template-columns:1fr 1fr}
  .guide-grid{grid-template-columns:1fr 1fr}
  .diff-cols{grid-template-columns:1fr}
  .final-cta-text{padding:60px 40px}
}
@media(max-width:768px){
  .hdr{padding:0 24px}.sec{padding:80px 24px}
  .nav{display:none}.m-toggle{display:block}
  .nav.open{display:flex;flex-direction:column;position:fixed;top:120px;right:0;bottom:0;left:0;background:var(--white);padding:32px 24px;gap:20px;z-index:999}
  .hero{padding:120px 24px 0}
  .func-grid,.change-list,.guide-grid,.trust-nums{grid-template-columns:1fr}
  .brand-pillars{display:grid;grid-template-columns:1fr;gap:0}
  .brand-pillar{max-width:100%;border-right:none;border-bottom:1px solid var(--border)}
  .brand-pillar:last-child{border-bottom:none}
  .final-cta-text{padding:60px 24px}
  .ftr{padding:40px 24px 24px}
  .ftr-top{flex-direction:column;gap:24px}
  .ftr-btm{flex-direction:column;gap:8px;text-align:center}
  .ftr-logo{max-width:200px}
}
.fade{opacity:0;transform:translateY(16px);transition:opacity .6s,transform .6s}
.fade.vis{opacity:1;transform:none}
@media(prefers-reduced-motion:reduce){.fade{opacity:1;transform:none;transition:none}}
</style>
</head>
<body>

<!-- SKIP LINK -->
<a href="#main" class="skip">メインコンテンツへ</a>

<!-- HEADER -->
<header class="hdr" id="hdr" role="banner">
  <a href="/"><img src="/ecmonsterlogo3.png" alt="ECMONSTER - ECの勝ち筋を、明確に。" class="hdr-logo"></a>
  <nav class="nav" id="nav" aria-label="メインナビゲーション">
    <a href="/#services">サービス</a>
    <a href="/achievement/">実績</a>
    <a href="/faq/">よくある質問</a>
    <a href="/login/">ログイン</a>
    <a href="/contact/" class="nav-cta">個別相談</a>
  </nav>
  <button class="m-toggle" aria-label="メニューを開く" aria-expanded="false" id="menuBtn"><span></span><span></span><span></span></button>
</header>

<!-- MAIN -->
<main id="main">

<!-- BLOCK 1: HERO -->
<section class="hero" aria-label="ファーストビュー">
  <div class="hero-copy">
    <h1>頭ひとつ抜ける<br>ECへ。</h1>
    <div class="hero-body">
      売れる商品、強い広告、最新の手法。<br>
      それだけでは、ECで頭ひとつ抜けることはできません。<br><br>
      必要なのは、<br>
      <strong>何を、なぜ、どの順番でやるかを明確にすること。</strong><br><br>
      ECモンスターは、戦略、判断、販売、開発、運営をつなぎ、<br>
      ECの勝ち筋を明確にする総合ブランドです。
    </div>
    <div class="hero-acts">
      <a href="/#guide" class="btn-d">まずは勝ち筋を整理する</a>
      <a href="/#guide" class="btn-g">サービスを見る</a>
    </div>
  </div>
  <div class="hero-img fade">
    <img src="/generated/hero_team.jpg" alt="ECモンスター戦略チームがモニターを見ながら議論している様子" width="1024" height="1024" loading="eager">
  </div>
</section>

<!-- BLOCK 2: EMPATHY -->
<section class="sec empathy" aria-label="課題共感">
  <div class="sec-in">
    <div class="empathy-layout">
      <div>
        <h2 class="fade" style="font-size:clamp(24px,3vw,32px);font-weight:800;color:var(--dark);line-height:1.5;margin-bottom:16px">こんな悩みはありませんか。</h2>
        <div class="empathy-grid">
          <div class="empathy-item fade">売上が伸びないが、何を変えるべきかわからない</div>
          <div class="empathy-item fade">広告、商品ページ、AI、運営体制の優先順位が決まらない</div>
          <div class="empathy-item fade">学んでも、自社でどう動くべきか整理できない</div>
          <div class="empathy-item fade">施策は増えているのに、全体がつながっていない</div>
          <div class="empathy-item fade">バックヤードや販売体制まで含めて見直したい</div>
          <div class="empathy-item fade">国内だけでなく、販路そのものを広げたい</div>
        </div>
        <div class="empathy-close fade">
          ECで伸び悩む理由は、努力不足ではありません。<br>
          <em>勝ち筋が曖昧なまま、手段だけが増えていること。</em>
        </div>
      </div>
      <div class="empathy-photo fade">
        <img src="/generated/empathy_struggle.jpg" alt="EC運営の課題に真剣に向き合うチーム" width="1024" height="1024" loading="lazy">
      </div>
    </div>
  </div>
</section>

<!-- BLOCK 3: BRAND DEFINITION -->
<section class="sec brand" aria-label="ブランド定義">
  <div class="sec-in">
    <div class="sec-ey fade">Brand</div>
    <h2 class="fade">ECの勝ち筋を、明確に。</h2>
    <div class="brand-body fade">
      ECモンスターは、単なるノウハウ提供でも、単なる代行でもありません。<br>
      AIコンサル、動画講座、WEBシステム開発、越境ECサイト、<br>
      販売戦略支援、バックヤード自動化、営業支援までつなぎ、<br><br>
      <strong>何をやるべきか、なぜやるべきか、どの順番で進めるべきか</strong><br>
      を明確にするブランドです。
    </div>
    <div class="brand-line fade" aria-hidden="true">
      <div class="brand-dots">
        <div class="brand-dot"></div><div class="brand-dot"></div><div class="brand-dot"></div>
        <div class="brand-dot"></div><div class="brand-dot"></div><div class="brand-dot"></div><div class="brand-dot"></div>
      </div>
      <div class="brand-merge"></div>
    </div>
    <div class="brand-pillars fade">
      <a href="/contact/" class="brand-pillar">戦略</a>
      <a href="/ecsystem/" class="brand-pillar">運営</a>
      <a href="/ai/" class="brand-pillar">判断</a>
      <a href="/echeroes3/" class="brand-pillar">実行</a>
    </div>
  </div>
