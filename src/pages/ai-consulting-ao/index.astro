---
import LPLayout from '../../layouts/LPLayout.astro'
---

<LPLayout title="自社ECに出店したけど利益が出ない…ECモンスターAIコンサル - EC モンスター" description="自社ECで売上が伸びない事業者向けのAIコンサルティングサービス。月額5,000円〜、24時間AI相談対応。">

  <!-- Hero -->
  <section class="bg-navy text-white py-20 text-center">
    <div class="max-w-4xl mx-auto px-4">
      <p class="text-lg text-slate mb-4">自社ECに出店したけど利益が出ない…</p>
      <h1 class="text-3xl md:text-4xl font-bold mb-8">ECモンスター<span class="text-primary">AIコンサル</span><br />自社EC編</h1>
      <a href="#apply" class="inline-block bg-primary hover:bg-primary-dark text-white font-bold px-8 py-4 rounded-full transition-colors text-lg">無料で体験する</a>
    </div>
  </section>

  <!-- Pain Points -->
  <section class="py-16">
    <div class="max-w-4xl mx-auto px-4">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {['思うように売れない', 'コンサル費用の効果がない', 'コスト増加による利益圧迫', '改善方法が不明確'].map((p) => (
          <div class="bg-red-50 rounded-xl p-4 text-center border border-red-100">
            <p class="font-medium text-dark">{p}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Instructor -->
  <section class="py-16 bg-slate-light">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-center mb-8 text-dark">江藤正親の実績</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {[
          { num: '3年連続', label: '楽天総合3位' },
          { num: '1,000店+', label: '指導実績' },
          { num: '80%+', label: '月商100万突破' },
          { num: '200店+', label: '年商1億超え' },
        ].map((s) => (
          <div class="text-center bg-white rounded-xl p-4 shadow-sm">
            <div class="text-xl font-bold text-primary">{s.num}</div>
            <div class="text-xs text-slate mt-1">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Traditional vs AI -->
  <section class="py-16">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-center mb-8 text-dark">ECコンサル3ヶ月コース vs AIコンサル</h2>
      <div class="overflow-x-auto">
        <table class="w-full bg-white rounded-xl shadow-lg overflow-hidden">
          <thead>
            <tr class="bg-navy text-white">
              <th class="px-4 py-3 text-left text-sm">項目</th>
              <th class="px-4 py-3 text-center text-sm">3ヶ月コース</th>
              <th class="px-4 py-3 text-center text-sm bg-primary">AIコンサル</th>
            </tr>
          </thead>
          <tbody>
            <tr class="border-b"><td class="px-4 py-3 text-sm font-medium">月額</td><td class="px-4 py-3 text-center text-sm">15万円（税別）</td><td class="px-4 py-3 text-center text-sm font-bold text-primary">5,000円〜</td></tr>
            <tr class="border-b bg-gray-50"><td class="px-4 py-3 text-sm font-medium">対応時間</td><td class="px-4 py-3 text-center text-sm">営業時間内</td><td class="px-4 py-3 text-center text-sm font-bold text-primary">24時間</td></tr>
            <tr><td class="px-4 py-3 text-sm font-medium">対象</td><td class="px-4 py-3 text-center text-sm">月商100万未満</td><td class="px-4 py-3 text-center text-sm font-bold text-primary">全レベル対応</td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Case Studies -->
  <section class="py-16 bg-slate-light">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-center mb-8 text-dark">実事例</h2>
      <div class="space-y-6">
        {[
          { name: '田中瑠美さん', platform: 'アパレル / Shopify', problem: '月30万円のコンサル費用が重圧に', result: 'AIコンサルで孤独感解消、毎日の業務ガイダンス実現' },
          { name: '原田美咲さん', platform: 'アクセサリー / BASE', problem: '月2〜3万円の売上、作業時間10時間/日', result: '作業時間1日3時間に短縮、月15万円に売上増加' },
          { name: '竹中美智子さん', platform: '美容健康 / Shopify', problem: '新人が質問できない環境、定着率低', result: 'AI導入で教育時間7割カット、質問の質向上' },
        ].map((c) => (
          <div class="bg-white rounded-xl shadow-md p-6 border-l-4 border-primary">
            <h3 class="font-bold text-dark mb-2">{c.name}（{c.platform}）</h3>
            <p class="text-sm text-slate mb-1"><span class="font-medium">課題：</span>{c.problem}</p>
            <p class="text-sm text-primary"><span class="font-medium text-dark">成果：</span>{c.result}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section class="py-16">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-center mb-8 text-dark">料金プラン</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="bg-white rounded-2xl shadow-lg p-6 border">
          <h3 class="text-lg font-bold text-dark mb-4">単体プラン</h3>
          <div class="text-3xl font-bold text-primary mb-2">月額 4,000円</div>
          <p class="text-sm text-slate mb-4">（税別）年額：40,000円</p>
          <p class="text-xs text-slate">24時間以内申込で初期費用無料</p>
        </div>
        <div class="bg-white rounded-2xl shadow-lg p-6 border-2 border-primary relative">
          <span class="absolute -top-3 left-4 bg-primary text-white text-xs font-bold px-3 py-1 rounded-full">おすすめ</span>
          <h3 class="text-lg font-bold text-dark mb-4">コンプリートプラン</h3>
          <div class="text-3xl font-bold text-primary mb-2">月額 5,000円</div>
          <p class="text-sm text-slate mb-4">（税別）年額：50,000円</p>
          <p class="text-xs text-slate">全プラットフォーム使い放題</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Special Offer -->
  <section class="py-16 bg-primary/5">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="text-2xl font-bold mb-4 text-dark">24時間以内のお申し込みで</h2>
      <p class="text-xl mb-6">初期費用 <span class="line-through text-slate">30,000円</span> → <span class="text-primary font-bold text-3xl">無料</span></p>
      <div class="text-sm text-slate space-y-1 mb-8">
        <p>特典1：AIコンサルスタートガイド</p>
        <p>特典2：失敗しないECスタートガイド</p>
        <p>特典3：商品開発→ファン獲得完全攻略ガイド</p>
      </div>
    </div>
  </section>

  <!-- Flow -->
  <section class="py-16">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-center mb-8 text-dark">導入の流れ</h2>
      <div class="flex flex-col md:flex-row gap-4 justify-center">
        {['ご契約', 'ご案内メール', 'Gmail設定', 'ご利用開始'].map((s, i) => (
          <div class="flex items-center gap-2">
            <div class="bg-primary text-white w-8 h-8 rounded-full flex items-center justify-center text-sm font-bold">{i + 1}</div>
            <span class="text-dark font-medium">{s}</span>
            {i < 3 && <span class="hidden md:block text-slate">→</span>}
          </div>
        ))}
      </div>
      <p class="text-center text-slate text-sm mt-4">いつでも解約可能・縛りなし</p>
    </div>
  </section>

  <!-- Apply Form -->
  <section id="apply" class="py-16 bg-navy text-white">
    <div class="max-w-md mx-auto px-4 text-center">
      <h2 class="text-2xl font-bold mb-6">お申し込み</h2>
      <p class="text-slate text-sm mb-8">※Gmailアドレスのみ対応</p>
      <form action="https://api.web3forms.com/submit" method="POST" class="space-y-4">
        <input type="hidden" name="access_key" value="ed53efba-9f1e-4bf3-aa00-7d68b21d8464" />
        <input type="hidden" name="redirect" value="https://ecmonster.jp/ai-consulting-ao/thanks/" />
        <input type="hidden" name="subject" value="AIコンサル自社EC編 申込" />
        <input type="email" name="email" required placeholder="Gmailアドレスを入力" class="w-full px-4 py-3 rounded-lg text-dark focus:outline-none focus:ring-2 focus:ring-primary" />
        <button type="submit" class="w-full bg-primary hover:bg-primary-dark text-white font-bold py-4 rounded-full transition-colors text-lg">
          無料で体験する
        </button>
      </form>
    </div>
  </section>

</LPLayout>
