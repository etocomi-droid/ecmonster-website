---
import BaseLayout from '../../layouts/BaseLayout.astro'
---

<BaseLayout
  title="お問い合わせ - EC モンスター"
  bodyClass="wp-singular page-template-default page page-id-2 page-parent wp-theme-ecmonster page-contact"
>
  <link slot="css" rel="stylesheet" href="/wp-assets/css/contact.css" />
  <link slot="css" rel="stylesheet" href="/wp-assets/css/cf7.css" />

<div class="page-wrap contact-wrap">
    <div class="l_inner">
        <section>
            <h1 class="page-ttl uline">お問い合わせ</h1>
            <p class="txt-c">ご質問等ございましたら<br class="sp">お気軽にお問い合わせください。<br>
                お問い合わせは、当社営業時間に<br class="sp">順次対応させていただきます。<br>
                内容によっては返信に時間を要する<br class="sp">場合がございます。<br>あらかじめご了承ください。</p>
            <div class="form-wrap">
                
<form action="https://api.web3forms.com/submit" method="POST" id="contact-form" class="wpcf7-form" aria-label="お問い合わせフォーム">
<input type="hidden" name="access_key" value="ed53efba-9f1e-4bf3-aa00-7d68b21d8464" />
<input type="hidden" name="redirect" value="/contact/thanks/" />
<input type="hidden" name="subject" value="ecmonster.jp お問い合わせ" />
<input type="checkbox" name="botcheck" class="hidden" style="display:none" />
<div class="l_box-wrap">
	<div class="item col">
		<p><label>
<input size="40" maxlength="400" class="wpcf7-form-control wpcf7-text" autocomplete="name" aria-required="true" placeholder="名前*" type="text" name="your-name" required /></label>
		</p>
	</div>
	<div class="item col">
		<p><label>
<input size="40" maxlength="400" class="wpcf7-form-control wpcf7-email wpcf7-text" autocomplete="email" aria-required="true" placeholder="メール*" type="email" name="your-email" required /></label>
		</p>
	</div>
	<div class="item">
		<p><label>
<input size="40" maxlength="400" class="wpcf7-form-control wpcf7-text" placeholder="電話番号" type="tel" name="your-tel" /></label>
		</p>
	</div>
	<div class="item">
		<p><label>
<textarea cols="40" rows="4" maxlength="2000" class="wpcf7-form-control wpcf7-textarea" placeholder="コメント*" name="your-message" required></textarea></label>
		</p>
	</div>
	<div class="item">
		<p><input class="wpcf7-form-control wpcf7-submit has-spinner" type="submit" value="送信する" id="submit-btn" />
		</p>
	</div>
</div>
</form>
<script is:inline>
document.getElementById('contact-form').addEventListener('submit', function(e) {
  var btn = document.getElementById('submit-btn');
  if (btn.disabled) { e.preventDefault(); return; }
  btn.disabled = true;
  btn.value = '送信中...';
  setTimeout(function() { btn.disabled = false; btn.value = '送信する'; }, 5000);
});
</script>
            </div>
        </section>
    </div>
</div>
<!--page-wrap -->

</BaseLayout>
