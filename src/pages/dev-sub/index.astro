<style>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
:root{--white:#FFF;--off:#FAFAFA;--border:#E8E8E8;--dark:#1A1A1A;--body:#3D3D3D;--light:#595959;--muted:#767676;--red:#C8272E;--red-pale:rgba(200,39,46,.05);--r:4px}
html{scroll-behavior:smooth}
body{font-family:'Noto Sans JP','Inter',sans-serif;background:var(--white);color:var(--body);line-height:1.9;letter-spacing:.03em;font-size:15px}
img{display:block;max-width:100%}
a{color:inherit;text-decoration:none}
strong{font-weight:700;color:var(--dark)}

.hdr{position:fixed;top:0;left:0;right:0;z-index:100;padding:0 60px;height:80px;display:flex;align-items:center;justify-content:space-between;background:rgba(255,255,255,.97);-webkit-backdrop-filter:blur(12px);backdrop-filter:blur(12px);border-bottom:1px solid var(--border)}
.hdr-logo{max-width:220px}
.nav{display:flex;align-items:center;gap:28px}
.nav a{font-size:13px;color:var(--light);font-weight:500;transition:.2s}
.nav a:hover{color:var(--dark)}
.nav .nav-cta{background:var(--dark);color:var(--white);padding:10px 22px;border-radius:var(--r);font-weight:600;transition:all .3s}
.nav .nav-cta:hover{background:var(--red)}
.m-toggle{display:none;background:none;border:none;cursor:pointer;width:32px;height:32px;position:relative}
.m-toggle span{display:block;width:22px;height:1.5px;background:var(--dark);position:absolute;left:5px;transition:.3s}
.m-toggle span:nth-child(1){top:9px}.m-toggle span:nth-child(2){top:15px}.m-toggle span:nth-child(3){top:21px}

.sec{padding:100px 60px}
.sec-in{max-width:1080px;margin:0 auto}
.sec-ey{font-size:12px;font-weight:600;color:var(--red);text-transform:uppercase;letter-spacing:.15em;margin-bottom:16px}
.sec-h2{font-size:clamp(22px,3vw,32px);font-weight:800;color:var(--dark);line-height:1.5;margin-bottom:20px}
.sec-lead{font-size:15px;color:var(--light);line-height:2;max-width:720px;margin-bottom:40px}
.btn-red{display:inline-flex;align-items:center;gap:8px;background:var(--red);color:var(--white);padding:16px 36px;border-radius:var(--r);font-size:15px;font-weight:700;transition:.3s}
.btn-red:hover{opacity:.85}
.btn-dark{display:inline-flex;align-items:center;gap:8px;background:var(--dark);color:var(--white);padding:16px 36px;border-radius:var(--r);font-size:15px;font-weight:700;transition:.3s}
.btn-dark:hover{background:var(--red)}
.btn-outline-w{display:inline-flex;align-items:center;gap:8px;background:transparent;color:rgba(255,255,255,.8);padding:15px 32px;border-radius:var(--r);font-size:14px;font-weight:600;border:1px solid rgba(255,255,255,.3);transition:.3s}
.btn-outline-w:hover{border-color:#fff;color:#fff}

/* HERO */
.hero{background:#111;padding:160px 60px 100px;text-align:center;min-height:100vh;display:flex;align-items:center}
.hero-in{max-width:880px;margin:0 auto}
.hero-ey{font-size:12px;font-weight:600;color:var(--red);text-transform:uppercase;letter-spacing:.15em;margin-bottom:24px}
.hero h1{font-size:clamp(26px,4.5vw,50px);font-weight:900;color:#fff;line-height:1.3;letter-spacing:-.01em;margin-bottom:28px}
.hero h1 em{font-style:normal;color:var(--red)}
.hero-sub{font-size:16px;color:rgba(255,255,255,.65);line-height:2.1;max-width:680px;margin:0 auto 48px}
.hero-acts{display:flex;gap:12px;justify-content:center;flex-wrap:wrap}
.hero-note{font-size:12px;color:rgba(255,255,255,.35);margin-top:20px}

/* COST COMPARE */
.cost-compare{display:grid;grid-template-columns:1fr auto 1fr;gap:0;align-items:center;max-width:680px;margin:40px 0}
.cost-box{padding:28px 24px;border:1px solid var(--border);border-radius:var(--r);text-align:center;background:var(--white)}
.cost-box.new{border-color:var(--red);background:var(--red-pale)}
.cost-label{font-size:11px;font-weight:700;color:var(--muted);letter-spacing:.1em;margin-bottom:10px}
.cost-box.new .cost-label{color:var(--red)}
.cost-val{font-size:28px;font-weight:900;color:var(--dark);line-height:1}
.cost-val span{font-size:14px;font-weight:400;color:var(--muted)}
.cost-box.new .cost-val{color:var(--red)}
.cost-sub{font-size:12px;color:var(--muted);margin-top:8px;line-height:1.6}
.cost-vs{font-size:20px;font-weight:800;color:var(--muted);padding:0 20px;text-align:center}

/* WORRIES */
.worry-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;max-width:800px;margin-bottom:32px}
.worry-item{display:flex;align-items:flex-start;gap:12px;padding:18px 20px;background:var(--white);border:1px solid var(--border);border-radius:var(--r);font-size:14px;color:var(--body);line-height:1.7}
.worry-item::before{content:'';width:5px;height:5px;border-radius:50%;background:var(--red);margin-top:8px;flex-shrink:0}
.worry-close{font-size:16px;color:var(--dark);font-weight:500;line-height:2;padding:24px 28px;border-left:3px solid var(--red);background:var(--off)}
.worry-close em{font-style:normal;color:var(--red);font-weight:700}

/* SERVICE */
.service-cols{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:36px}
.service-card{padding:24px 22px;border:1px solid var(--border);border-radius:var(--r);background:var(--white)}
.service-card-title{font-size:14px;font-weight:700;color:var(--dark);margin-bottom:10px;display:flex;align-items:center;gap:8px}
.service-icon{width:28px;height:28px;border:1.5px solid var(--dark);border-radius:var(--r);display:flex;align-items:center;justify-content:center;flex-shrink:0}
.service-icon svg{width:13px;height:13px;stroke:var(--dark);fill:none;stroke-width:1.5;stroke-linecap:round;stroke-linejoin:round}
.service-items{display:flex;flex-direction:column;gap:6px}
.service-item{font-size:12px;color:var(--light);line-height:1.6;display:flex;align-items:flex-start;gap:6px}
.service-item::before{content:'·';color:var(--red);font-weight:700;flex-shrink:0}

/* WHY */
.why-cards{display:grid;grid-template-columns:repeat(3,1fr);gap:16px}
.why-card{padding:28px 24px;background:var(--white);border:1px solid var(--border);border-radius:var(--r);text-align:center}
.why-num{font-size:36px;font-weight:900;color:var(--red);line-height:1;margin-bottom:12px}
.why-num span{font-size:14px;font-weight:400;color:var(--muted)}
.why-title{font-size:14px;font-weight:700;color:var(--dark);margin-bottom:8px}
.why-desc{font-size:12px;color:var(--light);line-height:1.8}

/* PLANS */
.plan-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px}
.plan-card{padding:32px 24px;border:1px solid var(--border);border-radius:var(--r);background:var(--white);display:flex;flex-direction:column}
.plan-card.featured{border-color:var(--red);background:var(--red-pale)}
.plan-tag{font-size:11px;font-weight:700;color:var(--muted);letter-spacing:.1em;text-transform:uppercase;margin-bottom:10px}
.plan-card.featured .plan-tag{color:var(--red)}
.plan-name{font-size:20px;font-weight:900;color:var(--dark);margin-bottom:6px}
.plan-price{font-size:28px;font-weight:900;color:var(--dark);margin-bottom:4px;line-height:1}
.plan-price span{font-size:13px;font-weight:400;color:var(--muted)}
.plan-desc{font-size:12px;color:var(--light);margin-bottom:20px;line-height:1.7;padding-bottom:20px;border-bottom:1px solid var(--border)}
.plan-features{display:flex;flex-direction:column;gap:8px;flex:1}
.plan-feature{font-size:12px;color:var(--body);display:flex;align-items:flex-start;gap:6px;line-height:1.6}
.plan-feature::before{content:'·';color:var(--red);font-weight:700;flex-shrink:0}
.plan-note{font-size:11px;color:var(--muted);margin-top:16px;line-height:1.6}

/* FLOW */
.flow-steps{display:flex;flex-direction:column;gap:0;max-width:640px}
.flow-step-item{display:flex;align-items:flex-start;gap:20px;padding:20px 0;border-bottom:1px solid var(--border)}
.flow-step-item:last-child{border-bottom:none}
.flow-num{width:36px;height:36px;border-radius:50%;background:var(--dark);color:var(--white);display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:700;flex-shrink:0;margin-top:2px}
.flow-text h4{font-size:14px;font-weight:700;color:var(--dark);margin-bottom:4px}
.flow-text p{font-size:13px;color:var(--light);line-height:1.7}

/* FAQ */
.faq-list{display:flex;flex-direction:column;gap:14px;max-width:720px}
.faq-item{border:1px solid var(--border);border-radius:var(--r);background:var(--white)}
.faq-q{padding:20px 24px;font-size:14px;font-weight:700;color:var(--dark);display:flex;gap:12px}
.faq-q-mark{color:var(--red);font-weight:800;font-size:16px;flex-shrink:0}
.faq-a{padding:0 24px 20px 48px;font-size:13px;color:var(--light);line-height:1.9}

/* CLOSING */
.closing{background:#111;text-align:center;padding:120px 60px}
.closing h2{font-size:clamp(20px,3vw,34px);font-weight:900;color:#fff;line-height:1.45;margin-bottom:24px}
.closing-body{font-size:15px;color:rgba(255,255,255,.65);line-height:2.2;max-width:620px;margin:0 auto 48px}
.closing-acts{display:flex;gap:12px;justify-content:center;flex-wrap:wrap}

/* FOOTER */
.ftr{background:#111;color:rgba(255,255,255,.65);padding:48px 60px 28px}
.ftr-in{max-width:1080px;margin:0 auto;display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:32px;padding-bottom:28px;border-bottom:1px solid rgba(255,255,255,.1);margin-bottom:20px}
.ftr-brand img{max-width:200px;background:#fff;padding:12px 16px;border-radius:var(--r)}
.ftr-brand p{font-size:12px;color:rgba(255,255,255,.4);margin-top:12px}
.ftr-links{display:flex;gap:48px}
.ftr-col h4{font-size:11px;font-weight:700;color:rgba(255,255,255,.5);letter-spacing:1.5px;margin-bottom:12px}
.ftr-col a{display:block;font-size:13px;color:rgba(255,255,255,.5);padding:3px 0;transition:.2s}
.ftr-col a:hover{color:rgba(255,255,255,.9)}
.ftr-btm{max-width:1080px;margin:0 auto;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:8px}
.ftr-btm p{font-size:11px;color:rgba(255,255,255,.3)}
.ftr-legal{display:flex;gap:16px}
.ftr-legal a{font-size:11px;color:rgba(255,255,255,.3);transition:.2s}
.ftr-legal a:hover{color:rgba(255,255,255,.65)}

@media(max-width:1024px){.why-cards{grid-template-columns:1fr 1fr}.plan-grid{grid-template-columns:1fr}.service-cols{grid-template-columns:1fr}.cost-compare{grid-template-columns:1fr;gap:12px}.cost-vs{padding:8px 0}}
@media(max-width:768px){
  .hdr{padding:0 24px}.sec{padding:72px 24px}.hero{padding:120px 24px 80px;min-height:auto}.closing{padding:80px 24px}
  .nav{display:none}.m-toggle{display:block}
  .nav.open{display:flex;flex-direction:column;position:fixed;top:80px;right:0;bottom:0;left:0;background:var(--white);padding:32px 24px;gap:20px;z-index:999}
  .worry-grid{grid-template-columns:1fr}.why-cards{grid-template-columns:1fr}
  .ftr{padding:40px 24px 24px}.ftr-in{flex-direction:column}.ftr-links{flex-direction:column;gap:24px}
  .ftr-btm{flex-direction:column;text-align:center}
}
.fade{opacity:0;transform:translateY(16px);transition:opacity .6s,transform .6s}
.fade.vis{opacity:1;transform:none}
</style>
</head>
<body>

<header class="hdr" id="hdr">
  <a href="/"><img src="/ecmonsterlogo3.png" alt="ECMONSTER" class="hdr-logo"></a>
  <nav class="nav" id="nav">
    <a href="/">トップ</a>
    <a href="/#services">サービス</a>
    <a href="/faq/">よくある質問</a>
    <a href="/contact/" class="nav-cta">無料相談</a>
  </nav>
  <button class="m-toggle" id="menuBtn"><span></span><span></span><span></span></button>
</header>

<main>

<!-- 1. HERO -->
<section class="hero">
  <div class="hero-in">
    <div class="hero-ey fade">サブスク社内システム開発部</div>
    <h1 class="fade"><em>1/10のコスト</em>で、<br>自社にシステム開発部門を持つ。</h1>
    <p class="hero-sub fade">「改修を頼んでも何ヶ月も待たされる」「外注すると高くて小さな改善ができない」「エクセル管理から脱却したいが予算がない」——そのビジネス側の不満を、月額サブスクで一気に解消します。</p>
    <div class="hero-acts fade">
      <a href="/contact/" class="btn-red">無料相談を申し込む</a>
      <a href="#plans" class="btn-outline-w">プランを見る</a>
    </div>
    <p class="hero-note fade">※ 社内開発者を正社員で雇用した場合との比較</p>
  </div>
</section>

<!-- 2. COST -->
<section class="sec" style="background:var(--white)">
  <div class="sec-in">
    <div class="sec-ey fade">Cost</div>
    <h2 class="sec-h2 fade">なぜ1/10のコストで可能なのか。</h2>
    <p class="sec-lead fade">エンジニアを正社員で採用すると、給与・社保・採用コスト・教育コストを含めると年間800万〜1,200万円かかります。外注も1プロジェクトで数百万。サブスク社内システム開発部なら、その負担を大幅に圧縮できます。</p>
    <div class="cost-compare fade">
      <div class="cost-box">
        <div class="cost-label">正社員エンジニア採用</div>
        <div class="cost-val">800<span>万円〜/年</span></div>
        <div class="cost-sub">給与＋社保＋採用コスト<br>＋教育コスト</div>
      </div>
      <div class="cost-vs">VS</div>
      <div class="cost-box new">
        <div class="cost-label">サブスク社内システム開発部</div>
        <div class="cost-val">月額<span>サブスク</span></div>
        <div class="cost-sub">固定費のみ・解約自由<br>採用・教育コスト不要</div>
      </div>
    </div>
    <p class="fade" style="font-size:14px;color:var(--muted);max-width:640px;line-height:1.8">AIを活用した開発フローと、必要な機能に絞ったスコープ設計により、従来の開発費用の大幅な削減を実現しています。</p>
  </div>
</section>

<!-- 3. WORRIES -->
<section class="sec" style="background:var(--off)">
  <div class="sec-in">
    <div class="sec-ey fade">Worries</div>
    <h2 class="sec-h2 fade">ビジネス側のこんな不満、ありませんか。</h2>
    <div class="worry-grid">
      <div class="worry-item fade">システム改修を依頼しても「3ヶ月待ち」と言われる</div>
      <div class="worry-item fade">外注すると高くて、小さな改善や自動化が頼めない</div>
      <div class="worry-item fade">社内ITはインフラ優先で、業務改善ツールに手が回らない</div>
      <div class="worry-item fade">エクセル・スプレッドシート管理の限界を感じている</div>
      <div class="worry-item fade">承認フロー・在庫管理・顧客管理をもっと効率化したい</div>
      <div class="worry-item fade">ちょっとした自動化ツールを作りたいが、誰に頼めばいいかわからない</div>
      <div class="worry-item fade">エンジニアを雇いたいが、採用コストと固定費が怖い</div>
      <div class="worry-item fade">既存システムとのAPI連携や、データ加工を気軽に依頼したい</div>
    </div>
    <div class="worry-close fade">これらは、<em>開発リソースが社内に固定されていないこと</em>から生まれる問題です。<br>サブスクで開発部門を持てば、依頼のたびに外注先を探す必要がなくなります。</div>
  </div>
</section>

<!-- 4. SERVICE -->
<section class="sec" style="background:var(--white)">
  <div class="sec-in">
    <div class="sec-ey fade">What We Build</div>
    <h2 class="sec-h2 fade">社内の「あったらいいのに」を、次々と形にします。</h2>
    <p class="sec-lead fade">業務効率化から顧客向けシステムまで、ビジネス側の要望をそのままシステムに落とし込みます。</p>
    <div class="service-cols">
      <div class="service-card fade">
        <div class="service-card-title">
          <div class="service-icon"><svg viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg></div>
          社内管理ツール・業務システム
        </div>
        <div class="service-items">
          <div class="service-item">在庫管理・発注管理システム</div>
          <div class="service-item">顧客管理・案件管理ツール</div>
          <div class="service-item">承認フロー・稟議システム</div>
          <div class="service-item">勤怠・シフト管理ツール</div>
          <div class="service-item">売上・KPI集計ダッシュボード</div>
        </div>
      </div>
      <div class="service-card fade">
        <div class="service-card-title">
          <div class="service-icon"><svg viewBox="0 0 24 24"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg></div>
          業務自動化・連携
        </div>
        <div class="service-items">
          <div class="service-item">ExcelデータのDB化・自動集計</div>
          <div class="service-item">外部サービスAPI連携</div>
          <div class="service-item">メール・通知の自動化</div>
          <div class="service-item">定期レポート自動生成</div>
          <div class="service-item">データ移行・クレンジング</div>
        </div>
      </div>
      <div class="service-card fade">
        <div class="service-card-title">
          <div class="service-icon"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10"/></svg></div>
          Webアプリ・顧客向けシステム
        </div>
        <div class="service-items">
          <div class="service-item">予約・申込フォームシステム</div>
          <div class="service-item">会員ポータル・マイページ</div>
          <div class="service-item">ECサイト機能拡張</div>
          <div class="service-item">LP・コーポレートサイト制作</div>
          <div class="service-item">問い合わせ対応ツール</div>
        </div>
      </div>
      <div class="service-card fade">
        <div class="service-card-title">
          <div class="service-icon"><svg viewBox="0 0 24 24"><path d="M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20z"/><path d="M12 8v4l3 3"/></svg></div>
          継続改善・運用サポート
        </div>
        <div class="service-items">
          <div class="service-item">既存システムのバグ修正・改善</div>
