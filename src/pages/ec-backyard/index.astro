<script is:inline>
(function(){
  // ヘッダースクロール
  var hdr = document.getElementById('hdr');
  if(hdr) window.addEventListener('scroll', function(){
    hdr.style.boxShadow = window.scrollY > 10 ? '0 2px 20px rgba(0,0,0,.08)' : '';
  }, {passive:true});

  // モバイルメニュー
  var btn = document.getElementById('menuBtn');
  var nav = document.getElementById('nav');
  if(btn && nav) btn.addEventListener('click', function(){
    var open = nav.classList.toggle('open');
    btn.setAttribute('aria-expanded', open);
  });

  // フェードイン
  var fades = document.querySelectorAll('.fade');
  if('IntersectionObserver' in window){
    var io = new IntersectionObserver(function(entries){
      entries.forEach(function(e){ if(e.isIntersecting){ e.target.classList.add('vis'); io.unobserve(e.target); } });
    },{threshold:.15});
    fades.forEach(function(el){ io.observe(el); });
  } else {
    fades.forEach(function(el){ el.classList.add('vis'); });
  }
})();
</script>
