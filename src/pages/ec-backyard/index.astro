<style>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
:root{
  --white:#FFF;--off:#FAFAFA;--gray:#F5F5F5;--border:#E8E8E8;
  --dark:#1A1A1A;--body:#3D3D3D;--light:#595959;--muted:#767676;
  --red:#C8272E;--red-pale:rgba(200,39,46,.05);
  --r:4px;
}
html{scroll-behavior:smooth}
body{font-family:'Noto Sans JP','Inter',sans-serif;background:var(--white);color:var(--body);line-height:1.9;letter-spacing:.03em;font-size:15px}
img{display:block;max-width:100%}
a{color:inherit;text-decoration:none}
a:focus-visible,button:focus-visible{outline:2px solid var(--red);outline-offset:2px}
strong{font-weight:700;color:var(--dark)}

/* SKIP */
.skip{position:absolute;top:-100px;left:16px;background:var(--dark);color:var(--white);padding:8px 16px;border-radius:var(--r);font-size:13px;z-index:200;transition:.2s}
.skip:focus{top:16px}

/* HEADER */
.hdr{position:fixed;top:0;left:0;right:0;z-index:100;padding:0 60px;height:80px;display:flex;align-items:center;justify-content:space-between;background:rgba(255,255,255,.97);-webkit-backdrop-filter:blur(12px);backdrop-filter:blur(12px);border-bottom:1px solid var(--border)}
.hdr-logo{max-width:220px}
.nav{display:flex;align-items:center;gap:28px}
.nav a{font-size:13px;color:var(--light);font-weight:500;transition:.2s}
.nav a:hover{color:var(--dark)}
.nav .nav-cta{background:var(--dark);color:var(--white);padding:10px 22px;border-radius:var(--r);font-weight:600;transition:all .3s}
.nav .nav-cta:hover{background:var(--red)}
.m-toggle{display:none;background:none;border:none;cursor:pointer;width:32px;height:32px;position:relative}
.m-toggle span{display:block;width:22px;height:1.5px;background:var(--dark);position:absolute;left:5px;transition:.3s}
.m-toggle span:nth-child(1){top:9px}.m-toggle span:nth-child(2){top:15px}.m-toggle span:nth-child(3){top:21px}

/* COMMON */
.sec{padding:100px 60px}
.sec-in{max-width:1080px;margin:0 auto}
.sec-ey{font-size:12px;font-weight:600;color:var(--red);text-transform:uppercase;letter-spacing:.15em;margin-bottom:16px}
.btn-d{display:inline-flex;align-items:center;gap:8px;background:var(--dark);color:var(--white);padding:16px 36px;border-radius:var(--r);font-size:15px;font-weight:700;transition:.3s}
.btn-d:hover{background:var(--red)}
.btn-d-red{display:inline-flex;align-items:center;gap:8px;background:var(--red);color:var(--white);padding:16px 36px;border-radius:var(--r);font-size:15px;font-weight:700;transition:.3s}
.btn-d-red:hover{opacity:.85}

/* HERO */
.hero{background:#111;padding:160px 60px 100px;text-align:center;min-height:100vh;display:flex;align-items:center}
.hero-in{max-width:860px;margin:0 auto}
.hero-ey{font-size:12px;font-weight:600;color:var(--red);text-transform:uppercase;letter-spacing:.15em;margin-bottom:24px}
.hero h1{font-size:clamp(28px,4vw,46px);font-weight:900;color:#fff;line-height:1.35;letter-spacing:-.01em;margin-bottom:28px}
.hero-sub{font-size:16px;color:rgba(255,255,255,.65);line-height:2.1;margin-bottom:48px;max-width:680px;margin-left:auto;margin-right:auto}
.hero-channels{display:flex;flex-wrap:wrap;justify-content:center;gap:10px;margin-bottom:48px}
.hero-tag{font-size:12px;color:rgba(255,255,255,.5);border:1px solid rgba(255,255,255,.15);padding:6px 14px;border-radius:20px}

/* ABOUT */
.about{background:var(--white)}
.about h2{font-size:clamp(22px,3vw,32px);font-weight:800;color:var(--dark);line-height:1.5;margin-bottom:24px}
.about-body{font-size:16px;color:var(--body);line-height:2.2;margin-bottom:32px;max-width:720px}
.about-points{display:grid;grid-template-columns:repeat(2,1fr);gap:12px;max-width:720px}
.about-point{display:flex;align-items:flex-start;gap:12px;padding:16px 20px;border:1px solid var(--border);border-radius:var(--r);font-size:14px;color:var(--body);line-height:1.7}
.about-point::before{content:'';width:5px;height:5px;border-radius:50%;background:var(--red);margin-top:9px;flex-shrink:0}

/* WORRIES */
.worries{background:var(--off)}
.worries h2{font-size:clamp(22px,3vw,32px);font-weight:800;color:var(--dark);line-height:1.5;margin-bottom:32px}
.worry-list{display:flex;flex-direction:column;gap:10px;max-width:720px;margin-bottom:32px}
.worry-item{display:flex;align-items:flex-start;gap:14px;padding:18px 22px;background:var(--white);border:1px solid var(--border);border-radius:var(--r);font-size:14px;color:var(--body);line-height:1.8}
.worry-check{width:18px;height:18px;border:1.5px solid var(--red);border-radius:3px;display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:2px}
.worry-check::after{content:'';width:6px;height:6px;border-radius:1px;background:var(--red)}
.worry-close{font-size:16px;color:var(--dark);line-height:2;font-weight:500;max-width:720px}
.worry-close em{font-style:normal;color:var(--red);font-weight:700}

/* SERVICES */
.services{background:var(--white)}
.services h2{font-size:clamp(22px,3vw,32px);font-weight:800;color:var(--dark);line-height:1.5;margin-bottom:20px}
.services-lead{font-size:15px;color:var(--light);line-height:2;max-width:680px;margin-bottom:40px}
.svc-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-bottom:40px}
.svc-card{padding:24px 20px;border:1px solid var(--border);border-radius:var(--r);background:var(--white)}
.svc-icon{width:32px;height:32px;border:1.5px solid var(--dark);border-radius:var(--r);display:flex;align-items:center;justify-content:center;margin-bottom:14px}
.svc-icon svg{width:14px;height:14px;stroke:var(--dark);fill:none;stroke-width:1.5;stroke-linecap:round;stroke-linejoin:round}
.svc-card p{font-size:13px;color:var(--body);line-height:1.8}
.services-strong{font-size:18px;font-weight:800;color:var(--dark);line-height:1.6;padding:28px 32px;border-left:3px solid var(--red);background:var(--off)}

/* BENEFITS */
.benefits{background:var(--off)}
.benefits h2{font-size:clamp(22px,3vw,32px);font-weight:800;color:var(--dark);line-height:1.5;margin-bottom:40px}
.benefit-cards{display:grid;grid-template-columns:1fr 1fr;gap:16px}
.benefit-card{padding:28px 24px;background:var(--white);border:1px solid var(--border);border-radius:var(--r)}
.benefit-num{font-size:11px;font-weight:700;color:var(--red);letter-spacing:.1em;margin-bottom:10px}
.benefit-title{font-size:16px;font-weight:700;color:var(--dark);margin-bottom:10px;line-height:1.5}
.benefit-desc{font-size:13px;color:var(--light);line-height:1.9}

/* COMPARE */
.compare{background:var(--white)}
.compare h2{font-size:clamp(22px,3vw,32px);font-weight:800;color:var(--dark);line-height:1.5;margin-bottom:40px}
.compare-cols{display:grid;grid-template-columns:1fr 1fr;gap:20px}
.compare-col{padding:32px 28px;border:1px solid var(--border);border-radius:var(--r)}
.compare-col.new{border-color:rgba(200,39,46,.3);background:var(--red-pale)}
.compare-label{font-size:11px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.1em;margin-bottom:20px}
.compare-col.new .compare-label{color:var(--red)}
.compare-items{display:flex;flex-direction:column;gap:10px}
.compare-item{font-size:14px;color:var(--body);line-height:1.8;display:flex;align-items:flex-start;gap:10px}
.compare-item::before{content:'';width:5px;height:5px;border-radius:50%;background:var(--muted);margin-top:10px;flex-shrink:0}
.compare-col.new .compare-item{color:var(--dark);font-weight:500}
.compare-col.new .compare-item::before{background:var(--red)}

/* FIT */
.fit{background:var(--off)}
.fit h2{font-size:clamp(22px,3vw,32px);font-weight:800;color:var(--dark);line-height:1.5;margin-bottom:32px}
.fit-list{display:flex;flex-direction:column;gap:10px;max-width:700px}
.fit-item{display:flex;align-items:center;gap:14px;padding:16px 22px;background:var(--white);border:1px solid var(--border);border-radius:var(--r);font-size:14px;color:var(--dark);font-weight:500}
.fit-dot{width:8px;height:8px;border-radius:50%;background:var(--red);flex-shrink:0}

/* CONSULT */
.consult{background:#111}
.consult h2{font-size:clamp(22px,3vw,32px);font-weight:800;color:#fff;line-height:1.5;margin-bottom:20px}
.consult-lead{font-size:15px;color:rgba(255,255,255,.65);line-height:2;max-width:640px;margin-bottom:40px}
.consult-items{display:flex;flex-direction:column;gap:10px;max-width:640px;margin-bottom:40px}
.consult-item{display:flex;align-items:flex-start;gap:12px;font-size:14px;color:rgba(255,255,255,.8);line-height:1.9}
.consult-item::before{content:'';width:5px;height:5px;border-radius:50%;background:var(--red);margin-top:10px;flex-shrink:0}
.consult-note{font-size:14px;color:rgba(255,255,255,.5);line-height:1.9;margin-bottom:40px;max-width:640px}

/* CLOSING */
.closing{background:var(--white);text-align:center;padding:120px 60px}
.closing h2{font-size:clamp(22px,3vw,34px);font-weight:900;color:var(--dark);line-height:1.5;margin-bottom:24px}
.closing-body{font-size:16px;color:var(--body);line-height:2.3;max-width:680px;margin:0 auto 48px}

/* FOOTER */
.ftr{background:#111;color:rgba(255,255,255,.65);padding:48px 60px 28px}
.ftr-in{max-width:1080px;margin:0 auto;display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:32px;padding-bottom:28px;border-bottom:1px solid rgba(255,255,255,.1);margin-bottom:20px}
.ftr-brand img{max-width:200px;background:#fff;padding:12px 16px;border-radius:var(--r)}
.ftr-brand p{font-size:12px;color:rgba(255,255,255,.4);margin-top:12px;line-height:1.8}
.ftr-links{display:flex;gap:48px}
.ftr-col h4{font-size:11px;font-weight:700;color:rgba(255,255,255,.5);letter-spacing:1.5px;margin-bottom:12px}
.ftr-col a{display:block;font-size:13px;color:rgba(255,255,255,.5);padding:3px 0;transition:.2s}
.ftr-col a:hover{color:rgba(255,255,255,.9)}
.ftr-btm{max-width:1080px;margin:0 auto;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:8px}
.ftr-btm p{font-size:11px;color:rgba(255,255,255,.3)}
.ftr-legal{display:flex;gap:16px}
.ftr-legal a{font-size:11px;color:rgba(255,255,255,.3);transition:.2s}
.ftr-legal a:hover{color:rgba(255,255,255,.65)}

/* RESPONSIVE */
@media(max-width:1024px){
  .svc-grid{grid-template-columns:1fr 1fr}
  .benefit-cards{grid-template-columns:1fr}
}
@media(max-width:768px){
  .hdr{padding:0 24px}.sec{padding:72px 24px}.hero{padding:120px 24px 80px}
  .nav{display:none}.m-toggle{display:block}
  .nav.open{display:flex;flex-direction:column;position:fixed;top:80px;right:0;bottom:0;left:0;background:var(--white);padding:32px 24px;gap:20px;z-index:999}
  .about-points{grid-template-columns:1fr}
  .svc-grid{grid-template-columns:1fr}
  .compare-cols{grid-template-columns:1fr}
  .ftr{padding:40px 24px 24px}
  .ftr-in{flex-direction:column}
  .ftr-links{flex-direction:column;gap:24px}
  .ftr-btm{flex-direction:column;text-align:center}
  .closing{padding:80px 24px}
}
.fade{opacity:0;transform:translateY(16px);transition:opacity .6s,transform .6s}
.fade.vis{opacity:1;transform:none}
@media(prefers-reduced-motion:reduce){.fade{opacity:1;transform:none;transition:none}}
</style>
</head>
<body>

<a href="#main" class="skip">メインコンテンツへ</a>

<!-- HEADER -->
<header class="hdr" id="hdr">
  <a href="/"><img src="/ecmonsterlogo3.png" alt="ECMONSTER - ECの勝ち筋を、明確に。" class="hdr-logo"></a>
  <nav class="nav" id="nav" aria-label="メインナビゲーション">
    <a href="/">トップ</a>
    <a href="/#services">サービス</a>
    <a href="/faq/">よくある質問</a>
    <a href="/contact/" class="nav-cta">個別相談</a>
  </nav>
  <button class="m-toggle" aria-label="メニューを開く" aria-expanded="false" id="menuBtn"><span></span><span></span><span></span></button>
</header>

<main id="main">

<!-- 1. HERO -->
<section class="hero">
  <div class="hero-in">
    <div class="hero-ey fade">EC全自動化集客戦略</div>
    <h1 class="fade">広告・SNS・コメント対応・記事制作まで。<br>ECの集客接点を、まとめて整理しませんか。</h1>
    <p class="hero-sub fade">Google広告、Meta広告、Facebook、Instagram、YouTube、TikTok投稿、コメント対応、バナー制作、動画制作、オウンドメディア運用。バラバラに管理されがちなEC集客を、ECモンスターがまとめて支援します。</p>
    <div class="hero-channels fade">
      <span class="hero-tag">Google広告</span>
      <span class="hero-tag">Meta広告</span>
      <span class="hero-tag">Instagram</span>
      <span class="hero-tag">Facebook</span>
      <span class="hero-tag">YouTube</span>
      <span class="hero-tag">TikTok</span>
      <span class="hero-tag">コメント対応</span>
      <span class="hero-tag">バナー制作</span>
      <span class="hero-tag">動画制作</span>
      <span class="hero-tag">記事制作</span>
    </div>
    <a href="/contact/" class="btn-d-red fade">個別面談を申し込む</a>
  </div>
</section>

<!-- 2. ABOUT -->
<section class="sec about" id="about">
  <div class="sec-in">
    <div class="sec-ey fade">About</div>
    <h2 class="fade">EC全自動化集客戦略とは</h2>
    <p class="about-body fade">
      EC全自動化集客戦略とは、広告、SNS投稿、コメント返信、動画制作、バナー制作、記事制作など、EC運営の集客に関わる複数の顧客接点を、個別に管理するのではなく、<strong>ひとつの流れとして整理・運用していく考え方</strong>です。<br><br>
      ECモンスターでは、これらをバラバラの施策として扱うのではなく、売上・粗利・反応率・継続性を見ながら、少人数でも回しやすい形へ整えていきます。
    </p>
    <div class="about-points">
      <div class="about-point fade">広告だけに頼らない</div>
      <div class="about-point fade">投稿だけで終わらせない</div>
      <div class="about-point fade">コメント返信も接客として活用する</div>
      <div class="about-point fade">コンテンツ制作まで含めて整理する</div>
    </div>
  </div>
</section>

<!-- 3. WORRIES -->
<section class="sec worries">
  <div class="sec-in">
    <div class="sec-ey fade">Worries</div>
    <h2 class="fade">こんなお悩みはありませんか</h2>
    <div class="worry-list">
      <div class="worry-item fade"><span class="worry-check"></span>広告は出しているが、SNSや記事まで手が回らない</div>
      <div class="worry-item fade"><span class="worry-check"></span>投稿しても、コメント対応が追いつかない</div>
      <div class="worry-item fade"><span class="worry-check"></span>バナーや動画が足りず、施策が続かない</div>
      <div class="worry-item fade"><span class="worry-check"></span>施策ごとに担当や外注先が分かれていて、全体が見えない</div>
      <div class="worry-item fade"><span class="worry-check"></span>やるべきことは多いのに、優先順位が整理できない</div>
      <div class="worry-item fade"><span class="worry-check"></span>人を増やさずに、もっと接点を増やしたい</div>
    </div>
    <p class="worry-close fade">もし当てはまるなら、必要なのは施策の追加ではなく、<br><em>顧客接点全体の整理</em>かもしれません。</p>
  </div>
</section>

<!-- 4. SERVICES -->
<section class="sec services">
  <div class="sec-in">
    <div class="sec-ey fade">Services</div>
    <h2 class="fade">ECモンスターが支援すること</h2>
    <p class="services-lead fade">ECモンスターは、広告運用だけ、投稿代行だけ、記事制作だけを切り出して考えるのではなく、EC運営に必要な集客接点を全体で見ながら支援します。</p>
    <div class="svc-grid">
      <div class="svc-card fade">
        <div class="svc-icon"><svg viewBox="0 0 24 24"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg></div>
        <p>Google広告、Meta広告の整理</p>
      </div>
      <div class="svc-card fade">
        <div class="svc-icon"><svg viewBox="0 0 24 24"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg></div>
        <p>Facebook、Instagram、YouTube、TikTok投稿の設計</p>
      </div>
      <div class="svc-card fade">
        <div class="svc-icon"><svg viewBox="0 0 24 24"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg></div>
        <p>コメント対応の整理</p>
      </div>
      <div class="svc-card fade">
        <div class="svc-icon"><svg viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg></div>
        <p>バナー・動画などのクリエイティブ方針整理</p>
      </div>
      <div class="svc-card fade">
        <div class="svc-icon"><svg viewBox="0 0 24 24"><path d="M12 20h9M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg></div>
        <p>オウンドメディアや記事コンテンツの方針整理</p>
      </div>
      <div class="svc-card fade">
        <div class="svc-icon"><svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg></div>
        <p>少人数で継続できる体制づくり</p>
      </div>
    </div>
    <div class="services-strong fade">バラバラな施策を、ひとつの考え方で整理する。<br>それが、この戦略の基本です。</div>
  </div>
</section>

<!-- 5. BENEFITS -->
<section class="sec benefits">
  <div class="sec-in">
    <div class="sec-ey fade">Benefits</div>
