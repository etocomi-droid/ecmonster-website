}
.eh-banner--gold{
  background:linear-gradient(rgba(179,120,0,.75),rgba(42,30,10,.85)),url('/wp-assets/img/eccc/ec-heroes/heroes2_05_pc.jpg') center/cover no-repeat;
}
.eh-banner-in{max-width:700px;margin:0 auto}
.eh-banner h2{
  font-size:clamp(24px,3.5vw,36px);
  font-weight:800;
  line-height:1.4;
  margin-bottom:12px;
}
.eh-banner-sub{
  font-size:15px;
  color:rgba(255,255,255,.85);
  line-height:1.8;
}

/* Blue Ocean section background */
.eh-section--blue{background:linear-gradient(180deg,#f0f6ff 0%,#f8fbff 100%)}
/* Grand Ocean section background */
.eh-section--gold{background:linear-gradient(180deg,#fffaf0 0%,#fffdf8 100%)}

/* ===== CARD GRID ===== */
.eh-grid{
  display:grid;
  grid-template-columns:repeat(2,1fr);
  gap:20px;
}

/* ===== LESSON CARD ===== */
.eh-card{
  background:var(--white);
  border:1px solid var(--border);
  border-radius:var(--r);
  overflow:hidden;
  transition:border-color .3s,box-shadow .3s;
}
.eh-card:hover{
  border-color:var(--red);
  box-shadow:0 4px 20px rgba(0,0,0,.06);
}
.eh-card-img{
  width:100%;
  height:180px;
  overflow:hidden;
}
.eh-card-img img{
  width:100%;
  height:100%;
  object-fit:cover;
  display:block;
}
.eh-card-body{
  padding:24px;
}
.eh-card-head{
  display:flex;
  align-items:baseline;
  gap:14px;
  margin-bottom:14px;
}
.eh-card-num{
  font-size:32px;
  font-weight:900;
  color:var(--red);
  line-height:1;
  letter-spacing:-.02em;
  flex-shrink:0;
}
.eh-card-title{
  font-size:17px;
  font-weight:700;
  color:var(--dark);
  line-height:1.4;
}
.eh-card-aim{
  font-size:14px;
  color:var(--body);
  line-height:1.9;
  margin-bottom:16px;
  padding-bottom:16px;
  border-bottom:1px solid var(--border);
}
.eh-card-aim strong{
  color:var(--red);
  font-weight:600;
  font-size:12px;
}

/* ===== DETAILS / ACCORDION ===== */
.eh-details{
  border-top:1px solid var(--border);
}
.eh-details:first-of-type{
  border-top:none;
}
.eh-details summary{
  font-size:13px;
  font-weight:600;
  color:var(--dark);
  padding:12px 0;
  cursor:pointer;
  list-style:none;
  display:flex;
  align-items:center;
  gap:8px;
  user-select:none;
}
.eh-details summary::-webkit-details-marker{display:none}
.eh-details summary::before{
  content:'+';
  display:inline-flex;
  align-items:center;
  justify-content:center;
  width:20px;
  height:20px;
  border-radius:50%;
  background:var(--red);
  color:var(--white);
  font-size:14px;
  font-weight:700;
  line-height:1;
  flex-shrink:0;
  transition:transform .2s;
}
.eh-details[open] summary::before{
  content:'\2212';
}
.eh-details ul{
  margin:0 0 12px 28px;
  padding:0;
  list-style:none;
}
.eh-details li{
  font-size:13px;
  color:var(--body);
  line-height:1.9;
  padding:2px 0;
  position:relative;
  padding-left:14px;
}
.eh-details li::before{
