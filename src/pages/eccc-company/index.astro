<BaseLayout title="会社概要-株式会社ECコンサルカンパニー"
  description="株式会社ECコンサルカンパニー　事業内容：Webシステム開発構築、越境EC運営代行、ホームページ制作、ECサイト構築、ECサイト運用、ECコンサルティング事業、各種セミナーなど">
<link rel="stylesheet" href="/wp-assets/css/eccc-pages.css" slot="css" />

<nav class="wrap950">
	<ul class="nav_btn">
	   <li><a href="/eccc-company/" class="active">会社概要</a></li>
	   <li class="pc"><a href="/eccc-company/philosophy/">企業理念</a></li>
	   <li><a href="/eccc-company/message/">トップメッセージ</a></li>
	   <li class="pc"><a href="/eccc-company/access/">アクセス</a></li>
	   <li><a href="/eccc-company/recruit/">求人情報</a></li>	   
	</ul>
</nav>
  <div id="sub_contents" class="wrap950 padding100" style="padding-bottom:20px;">

    <section class="company">
      <h2 class="h2_sub btm_mar40">会社概要</h2>
      <section class="btm_mar30">
        <h3 class="btm_mar10"><img src="/wp-assets/img/eccc/h2_company01.jpg" alt="概要"></h3>
        <table class="company_tbl" summary="概要">
          <tr>
            <th>会社名</th>
            <td>株式会社ECコンサルカンパニー</td>
          </tr>
          <tr>
            <th>住所</th>
            <td>〒105-0013<br />
              東京都港区浜松町2-2-3　磯山ビル3階</td>
          </tr>
          <tr>
            <th>連絡先</th>
            <td>ＴＥＬ　：03-5166-8000</td>
          </tr>
          <tr>
            <th>設立</th>
            <td>2000年10月</td>
          </tr>
          <tr>
            <th>資本金</th>
            <td>1,600万円</td>
          </tr>
          <tr>
            <th>代表者</th>
            <td>江藤 政親</td>
          </tr>
          <tr>
            <th>従業員数</th>
            <td>7名（アルバイトを含む）</td>
          </tr>
          <tr>
            <th>事業内容</th>
            <td>ホームページ制作<br />
              ECサイト構築<br />
              ECサイト運用<br />
              ECコンサルティング事業<br />
              各種セミナー</td>
          </tr>
          <tr>
            <th>主要取引先</th>
            <td>株式会社電通<br>株式会社グランビスタホテル＆リゾート<br>カルチュア・コンビニエンス・クラブ株式会社<br>各地方自治体<br>株式会社学研ロジスティクス<br>大建工業株式会社<br>他多数</td>
          </tr>
        </table>
      </section>
      <section>
        <h3 class="btm_mar10"><img src="/wp-assets/img/eccc/h2_company02.jpg" alt="沿革"></h3>
        <table class="history_tbl" summary="沿革">
          <tr>
            <th>1999年</th>
            <td>EC運営事業開始</td>
          </tr>
          <tr>
            <th>2000年</th>
            <td>法人化 月商4500万円 ネット販売売上ワイン売り上げ世界一を誇る</td>
          </tr>
          <tr>
            <th>2001年</th>
            <td>コンサル事業スタート<br />
              1999，2000，2001年3年連続楽天ショップオブザイヤー<br />
              総合3位受賞店舗運営</td>
          </tr>
          <tr>
            <th>2002年</th>
            <td>クライアント総売上17億円を達成</td>
          </tr>
          <tr>
            <th>2004年</th>
            <td>スクール事業スタート</td>
          </tr>
          <tr>
            <th>2007年</th>
            <td>ホームページ制作事業スタート</td>
          </tr>
          <tr>
            <th>2008年</th>
            <td>資本金1600万円増資 株式会社に組織変更</td>
          </tr>
          <tr>
            <th>2006年</th>
            <td>指導店舗500社突破　200社が年商1億円以上　最高年商10億円</td>
          </tr> 
          <tr>
            <th>2011年</th>
            <td>サポート支援ショップ　1000社を超える</td>
          </tr>
          <tr>
            <th>2013年</th>
            <td>一般社団法人ジャパンEコマースコンサルタント協会に設立、参画</td>
          </tr> 
          <tr>
            <th>2017年</th>
            <td>熱中通販プロジェクト参画</td>
          </tr> 
          <tr>
            <th>2017年</th>
            <td>一般社団法人日本イーコマース学会設立</td>
          </tr> 
          
        </table>
      </section>
    </section>
    
