---
import NewLayout from '../layouts/NewLayout.astro'
---

<NewLayout
  title="ログイン - ECモンスター"
  description="ECモンスターの各種サービスをご利用中のお客様専用ログインページです。"
>

<style>
  .login-wrap {
    max-width: 480px;
    margin: 0 auto;
    padding: 60px 20px 80px;
  }
  .login-title {
    font-size: clamp(24px, 3vw, 32px);
    font-weight: 800;
    color: var(--dark);
    text-align: center;
    margin-bottom: 32px;
  }
  .login-form {
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: var(--r);
    padding: 40px 30px;
  }
  .login-form .form-group {
    margin-bottom: 20px;
  }
  .login-form label {
    display: block;
    font-weight: 700;
    margin-bottom: 6px;
    font-size: 14px;
    color: var(--dark);
  }
  .login-form input[type="email"],
  .login-form input[type="password"] {
    width: 100%;
    padding: 12px 14px;
    border: 1px solid var(--border);
    border-radius: var(--r);
    font-size: 16px;
    box-sizing: border-box;
    font-family: inherit;
  }
  .login-form input[type="email"]:focus,
  .login-form input[type="password"]:focus {
    outline: none;
    border-color: var(--red);
    box-shadow: 0 0 0 2px rgba(200, 39, 46, 0.15);
  }
  .login-btn {
    display: block;
    width: 100%;
    padding: 14px;
    background: var(--dark);
    color: var(--white);
    border: none;
    border-radius: var(--r);
    font-size: 16px;
    font-weight: 700;
    cursor: pointer;
    margin-top: 10px;
    transition: background 0.3s;
    font-family: inherit;
  }
  .login-btn:hover {
    background: var(--red);
  }
  .login-links {
    text-align: center;
    margin-top: 20px;
    font-size: 14px;
  }
  .login-links a {
    color: var(--red);
    text-decoration: underline;
  }
  .login-desc {
    text-align: center;
    color: var(--muted);
    font-size: 14px;
    margin-top: 24px;
    line-height: 1.8;
  }
  .login-desc a {
    color: var(--red);
    text-decoration: underline;
  }
  .login-error {
    background: rgba(200, 39, 46, 0.05);
    border: 1px solid rgba(200, 39, 46, 0.3);
    color: var(--red);
    padding: 12px;
    border-radius: var(--r);
    margin-bottom: 16px;
    font-size: 14px;
    display: none;
  }
</style>

<div class="login-wrap">
  <h1 class="login-title">ログイン</h1>
  <div class="login-form">
    <div class="login-error" id="loginError">
      メールアドレスまたはパスワードが正しくありません。
    </div>
    <form id="loginForm" action="https://ecmonster.jp/accounts/login/" method="GET">
      <div class="form-group">
        <label for="email">メールアドレス</label>
        <input type="email" id="email" name="email" required placeholder="example@email.com" />
      </div>
      <div class="form-group">
        <label for="password">パスワード</label>
        <input type="password" id="password" name="password" required placeholder="パスワードを入力" />
      </div>
      <button type="submit" class="login-btn">ログイン</button>
    </form>
    <div class="login-links">
      <a href="/contact/">パスワードをお忘れの方</a>
    </div>
  </div>
  <p class="login-desc">
    ECモンスターの各種サービス（AIコンサル、楽天市場動画講座等）を<br>ご利用中のお客様専用ログインページです。<br>
    <a href="/ai/">新規のお客様はこちら</a>
  </p>
</div>

<script is:inline>
  document.getElementById('loginForm').addEventListener('submit', function(e) {
    e.preventDefault();
    window.location.href = 'https://ecmonster.jp/accounts/login/';
  });
</script>

</NewLayout>
