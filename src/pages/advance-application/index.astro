---
import BaseLayout from '../../layouts/BaseLayout.astro'
---

<BaseLayout title="ECモンスターコミュニティ先行予約申込 - EC モンスター" description="ECモンスターコミュニティへの入会先行予約。登録無料。入会金無料の特別価格でご案内します。">

  <section class="py-20">
    <div class="max-w-2xl mx-auto px-4">
      <h1 class="text-3xl font-bold text-center mb-6 text-dark">ECモンスターコミュニティ<br />先行予約申込</h1>
      <p class="text-slate text-center mb-12">
        登録は無料です。コミュニティの準備完了後に、入力いただいたメールアドレスに入会金無料の特別価格でのご案内をお送りさせていただきます。
      </p>

      <form action="https://api.web3forms.com/submit" method="POST" class="space-y-6">
        <input type="hidden" name="access_key" value="ed53efba-9f1e-4bf3-aa00-7d68b21d8464" />
        <input type="hidden" name="redirect" value="https://ecmonster.jp/advance-application/aa-thanks/" />
        <input type="hidden" name="subject" value="コミュニティ先行予約申込" />

        <div>
          <label for="name" class="block text-sm font-medium text-dark mb-2">お名前 <span class="text-primary">*</span></label>
          <input type="text" id="name" name="name" required class="w-full px-4 py-3 border rounded-lg focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary" />
        </div>

        <div>
          <label for="email" class="block text-sm font-medium text-dark mb-2">メールアドレス <span class="text-primary">*</span></label>
          <input type="email" id="email" name="email" required class="w-full px-4 py-3 border rounded-lg focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary" />
        </div>

        <div class="text-center">
          <button type="submit" class="bg-primary hover:bg-primary-dark text-white font-bold px-8 py-4 rounded-full transition-colors text-lg">
            先行予約に申し込む（無料）
          </button>
        </div>
      </form>
    </div>
  </section>

</BaseLayout>
