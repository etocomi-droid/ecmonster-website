---
import BaseLayout from '../layouts/BaseLayout.astro'
---

<BaseLayout title="特定商取引法に基づく表示 - EC モンスター">

  <section class="py-20">
    <div class="max-w-4xl mx-auto px-4">
      <h1 class="text-3xl font-bold text-center mb-12 text-dark">特定商取引法に基づく表示</h1>

      <div class="bg-white rounded-2xl shadow-lg overflow-hidden">
        <table class="w-full">
          <tbody class="divide-y">
            {[
              ['販売事業者名', 'アンリミテッドアム株式会社'],
              ['運営統括責任者', '江藤 正親'],
              ['所在地', '〒103-0025 東京都中央区日本橋茅場町2丁目14−1 第一井上ビル 301'],
              ['電話番号', '03-4400-8628'],
              ['お問い合わせ時間', '平日10:00〜17:00'],
              ['ホームページ', 'https://ecmonster.jp/'],
              ['電子メール', 'info@ecmonster.jp'],
              ['販売価格', '22,000円（税込）'],
              ['商品代金以外に必要な費用', '消費税 2,000円'],
              ['お支払方法', 'クレジットカード'],
              ['注文確認までにかかる時間', '24時間以内'],
              ['商品発送までにかかる日数', '24時間以内'],
              ['商品引渡し時期', '決済完了後、24時間以内にメールにてご案内いたします。'],
              ['返品・キャンセル', '購入日から3日以内にお問い合わせフォームで連絡可能'],
              ['不良品について', 'ご注文内容と異なる場合、またはデータ等が破損している場合は3日以内にご連絡ください。状況確認後に改めてサービスを提供いたします。'],
            ].map(([label, value]) => (
              <tr>
                <th class="px-6 py-4 text-left bg-slate-light text-sm font-medium text-dark w-1/3 align-top">{label}</th>
                <td class="px-6 py-4 text-sm text-slate">{value}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

</BaseLayout>
