     <p>必要事項に入力の上、お申し込みはこちらボタンを押してください。</p>
     <div id="mw_wp_form_mw-wp-form-4849" class="mw_wp_form mw_wp_form_input  ">
          [mwform_formkey key="4868"]
        </div> -->
<div class="cv-common-tel">
                <p><strong>お問い合わせ・お申し込み</strong></p>
                <a href="tel:0351668000" class="tel"><img src="/wp-assets/img/eccc/top_tel.png" alt="03-5166-8000"></a>
            </div>
    </section>
  </section>

</div>
<script src="https://ajax.googleapis.com/ajax/libs/jquery/3.3.1/jquery.min.js"></script>
<script type="text/javascript">
  $(function(){
  
    //.accordion2の中のp要素がクリックされたら
  $('.accordion2 p').click(function(){

    //クリックされた.accordion2の中のp要素に隣接する.accordion2の中の.innerを開いたり閉じたりする。
    $(this).next('.accordion2 .inner').slideToggle();

    //クリックされた.accordion2の中のp要素以外の.accordion2の中のp要素に隣接する.accordion2の中の.innerを閉じる
    $('.accordion2 p').not($(this)).next('.accordion2 .inner').slideUp();

  });
});
</script>`;
