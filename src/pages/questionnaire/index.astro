---
import BaseLayout from '../../layouts/BaseLayout.astro'
---

<BaseLayout title="AIコンサルアンケート - EC モンスター">

  <section class="py-20">
    <div class="max-w-2xl mx-auto px-4">
      <h1 class="text-3xl font-bold text-center mb-12 text-dark">AIコンサルアンケート</h1>

      <form action="https://api.web3forms.com/submit" method="POST" class="space-y-8">
        <input type="hidden" name="access_key" value="ed53efba-9f1e-4bf3-aa00-7d68b21d8464" />
        <input type="hidden" name="redirect" value="https://ecmonster.jp/questionnaire/questionnaire-thanks/" />
        <input type="hidden" name="subject" value="AIコンサルアンケート回答" />

        <div>
          <label for="q1" class="block text-sm font-medium text-dark mb-2">
            ECモンスターAIコンサルを使って良かった点を教えてください <span class="text-primary">*</span>
          </label>
          <textarea id="q1" name="良かった点" rows="4" required class="w-full px-4 py-3 border rounded-lg focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary"></textarea>
        </div>

        <div>
          <label for="q2" class="block text-sm font-medium text-dark mb-2">
            ECモンスターAIコンサルを使う中での、お悩み事や疑問があれば教えてください <span class="text-primary">*</span>
          </label>
          <textarea id="q2" name="お悩み・疑問" rows="4" required class="w-full px-4 py-3 border rounded-lg focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary"></textarea>
        </div>

        <div>
          <label for="q3" class="block text-sm font-medium text-dark mb-2">
            「もっとこんな質問にも答えられるようにしてほしい！」などのご要望があれば教えてください
          </label>
          <textarea id="q3" name="ご要望" rows="4" class="w-full px-4 py-3 border rounded-lg focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary"></textarea>
        </div>

        <div class="text-center">
          <button type="submit" class="bg-primary hover:bg-primary-dark text-white font-bold px-8 py-4 rounded-full transition-colors text-lg">
            送信する
          </button>
        </div>
      </form>
    </div>
  </section>

</BaseLayout>
