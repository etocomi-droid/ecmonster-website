---
import BaseLayout from '../../layouts/BaseLayout.astro'
---

<BaseLayout
  title="AIコンサルアンケート - EC モンスター"
  bodyClass="wp-singular page-template-default page page-id-149 page-parent wp-theme-ecmonster page-questionnaire"
>
  <link slot="css" rel="stylesheet" href="/wp-assets/css/questionnaire.css" />
  <link slot="css" rel="stylesheet" href="/wp-assets/css/cf7.css" />

<div class="page-wrap questionnaire-wrap">
    <div class="l_inner">
        <section>
            <h1 class="page-ttl">アンケートに<br class="sp">ご協力ください。</h1>
            <img src="/wp-assets/img/questionnaire/img_01.png" alt="">
            <div class="form-wrap">
                
<form action="https://api.web3forms.com/submit" method="POST" id="questionnaire-form" class="wpcf7-form" aria-label="アンケートフォーム">
<input type="hidden" name="access_key" value="ed53efba-9f1e-4bf3-aa00-7d68b21d8464" />
<input type="hidden" name="redirect" value="/questionnaire/questionnaire-thanks/" />
<input type="hidden" name="subject" value="ecmonster.jp AIコンサルアンケート" />
<input type="checkbox" name="botcheck" class="hidden" style="display:none" />
<div class="item">
	<p>■ECモンスターAIコンサルを使って良かった点を教えてください<span class="red">（必須）</span>
	</p>
	<p><textarea cols="40" rows="3" maxlength="2000" class="wpcf7-form-control wpcf7-textarea" aria-required="true" name="good-point" required></textarea>
	</p>
</div>
<div class="item">
	<p>■ECモンスターAIコンサルを使う中での、お悩み事や疑問があれば教えてください<span class="red">（必須）</span>
	</p>
	<p><textarea cols="40" rows="3" maxlength="2000" class="wpcf7-form-control wpcf7-textarea" aria-required="true" name="questions" required></textarea>
	</p>
</div>
<div class="item">
	<p>■「もっとこんな質問にも答えられるようにしてほしい！」などのご要望があれば、教えてください
	</p>
	<p><textarea cols="40" rows="3" maxlength="2000" class="wpcf7-form-control wpcf7-textarea" name="request"></textarea>
	</p>
</div>
<div class="item">
	<p><input class="wpcf7-form-control wpcf7-submit has-spinner" type="submit" value="送信" id="questionnaire-submit-btn" />
	</p>
</div>
</form>
<script is:inline>
document.getElementById('questionnaire-form').addEventListener('submit', function(e) {
  var btn = document.getElementById('questionnaire-submit-btn');
  if (btn.disabled) { e.preventDefault(); return; }
  btn.disabled = true;
  btn.value = '送信中...';
  setTimeout(function() { btn.disabled = false; btn.value = '送信'; }, 5000);
});
</script>
            </div>
        </section>
    </div>
</div>
<!--page-wrap -->

</BaseLayout>
