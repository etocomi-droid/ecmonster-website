---
import BaseLayout from '../../layouts/BaseLayout.astro'
---

<BaseLayout title="アンケート送信完了 - EC モンスター">
  <section class="py-32 text-center">
    <div class="max-w-2xl mx-auto px-4">
      <div class="text-6xl mb-6">📝</div>
      <h1 class="text-3xl font-bold mb-6 text-dark">アンケートにご協力いただきありがとうございます</h1>
      <p class="text-slate mb-8">いただいたご意見はサービス改善に活用させていただきます。</p>
      <a href="/" class="inline-block bg-primary hover:bg-primary-dark text-white font-bold px-8 py-4 rounded-full transition-colors">トップページへ戻る</a>
    </div>
  </section>
</BaseLayout>
