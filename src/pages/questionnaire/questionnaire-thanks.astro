---
import BaseLayout from '../../layouts/BaseLayout.astro'
---

<BaseLayout
  title="送信完了 - EC モンスター"
  bodyClass="wp-singular page-template-default page page-id-152 page-child parent-pageid-149 wp-theme-ecmonster page-questionnaire-thanks"
>
  <link slot="css" rel="stylesheet" href="/wp-assets/css/questionnaire.css" />
  <link slot="css" rel="stylesheet" href="/wp-assets/css/cf7.css" />

<div class="page-wrap questionnaire-wrap">
    <div class="l_inner">
        <section>
            <h1 class="page-ttl">ご協力ありがとうございました！</h1>
            <p class="txt-thanks">特典はこちらから<br>ダウンロードください。</p>
            <div class="form-wrap">
                <a class="btn"
                    href="/wp-assets/img/questionnaire/ecai_enquete.pdf"
                    download="楽天市場/Amazon商品名制作補助ツール.pdf"
                    onclick="javascript: downloadFile('/wp-assets/img/questionnaire/ecai_enquete.pdf', '楽天市場/Amazon商品名制作補助ツール.pdf'); return false;">特典をダウンロード</a>
            </div>
        </section>
    </div>
</div>
<!--page-wrap -->

</BaseLayout>
